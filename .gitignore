.tox/
.nox/
.coverage
.coverage.*
.cache
nosetests.xml
coverage.xml
*.cover
*.py,cover
.hypothesis/
.pytest_cache/
test_output/
test_results/

# Translations
*.mo
*.pot

# Django stuff:
*.log
